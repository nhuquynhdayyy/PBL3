<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - TourismWeb</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="icon" href="~/favicon.ico" type="image/x-icon" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

    @RenderSection("Styles", required: false)
</head>

<body id="@ViewData["BodyId"]" class="d-flex flex-column min-vh-100">

    @if (ViewData["HideNavbar"] == null || !(bool)ViewData["HideNavbar"])
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">TourismWeb</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Location" asp-action="Index">
                                <i class="fas fa-map-marker-alt"></i> Địa điểm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Guide" asp-action="Index">
                                <i class="fas fa-book"></i> Cẩm nang du lịch
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Experience" asp-action="Index">
                                <i class="fas fa-walking"></i> Trải nghiệm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">
                                <i class="fas fa-envelope"></i> Liên hệ
                            </a>
                        </li>
                    </ul>

                    <form class="d-flex">
                        <input class="form-control me-2" type="search" placeholder="Tìm kiếm...">
                        <button class="btn btn-outline-light" type="submit"><i class="fas fa-search"></i></button>
                    </form>

                    <div class="dropdown ms-3">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" id="userMenu"
                            data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                            <li><a class="dropdown-item" asp-controller="Users" asp-action="Login">Đăng nhập</a></li>
                            <li><a class="dropdown-item" asp-controller="Users" asp-action="Register">Đăng ký</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    }

    <main role="main" class="flex-grow-1">
        <div>
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Khởi tạo Swiper slider
            var swiper = new Swiper(".swiper-container", {
                slidesPerView: 3,
                spaceBetween: 40,
                centeredSlides: "auto",
                loop: true,
                autoplay: {
                    delay: 4000,
                    disableOnInteraction: false,
                },
                speed: 1000,
                navigation: {
                    nextEl: ".swiper-button-next",
                    prevEl: ".swiper-button-prev",
                },
                pagination: {
                    el: ".swiper-pagination",
                    clickable: true,
                },
                grabCursor: true
            });

            // Khởi tạo dropdown Bootstrap
            var dropdownElementList = [].slice.call(document.querySelectorAll('.dropdown-toggle'));
            var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
                return new bootstrap.Dropdown(dropdownToggleEl);
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <footer class="bg-dark text-light text-center py-3 mt-auto">
        <div class="container">
            &copy; 2025 - TourismWeb - <a asp-controller="Home" asp-action="Privacy" class="text-light">Privacy</a>
        </div>

        <section class="footer-wrapper">
            <div class="footer-content">
                <div class="footer-logo">
                    <img src="~/images/logo2.webp" alt="Logo">
                    <p>WELCOME TourismWeb!</p>
                    <div class="footer-social">
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-pinterest"></i></a>
                    </div>
                </div>

                <div class="footer-links">
                    <h4>Điều hướng</h4>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a asp-controller="Location" asp-action="Index">Địa điểm</a></li>
                        <li><a asp-controller="Guide" asp-action="Index">Cẩm nang du lịch</a></li>
                        <li><a asp-controller="Experience" asp-action="Index">Trải nghiệm</a></li>
                        <li><a asp-controller="Contact" asp-action="Index">Liên hệ</a></li>
                    </ul>

                </div>

                <div class="footer-instagram">
                    <h4>Instagram</h4>
                    <div class="footer-gallery">
                        <img src="~/images/danang.jpg" alt="">
                        <img src="~/images/hoian.jpg" alt="">
                        <img src="~/images/hue.jpg" alt="">
                        <img src="~/images/nhatrang.jpg" alt="">
                        <img src="~/images/phongnha.jpg" alt="">
                        <img src="~/images/xinchao3.jpg" alt="">
                    </div>
                </div>

                <div class="footer-subscribe">
                    <h4>Theo dõi</h4>
                    <p>Đăng ký nhận tin tức</p>
                    <input type="email" placeholder="Email...">
                    <button>ĐĂNG KÝ</button>
                </div>
            </div>
        </section>
    </footer>

</body>

</html>
